{
  "name": "curve-watch",
  "version": "0.1.0",
  "private": true,
  "description": "An animated time-machine through 60 years of U.S. Treasury yield curves.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "verify:static": "node scripts/verify-static-build.mjs",
    "preview": "vite preview",
    "bake:data": "node scripts/bake-yield-data.mjs",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@observablehq/plot": "^0.6.16",
    "d3": "^7.9.0"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@vitest/coverage-v8": "^4.1.10",
    "prettier": "^3.9.5",
    "typescript": "^7.0.2",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  }
}
